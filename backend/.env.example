# Environment Variables
# Copy this file to .env and fill in the values.
# Never commit the .env file to version control.

# ─── Application ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Database ────────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://campusflow:campusflow_dev@localhost:5432/campusflow?schema=public

# ─── Redis ───────────────────────────────────────────────────────────────────────
# Format: redis://[:password@]host[:port][/db-number]
REDIS_URL=redis://localhost:6379

# ─── Authentication ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_MINIMUM_64_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_STRONG_SECRET_MINIMUM_64_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Matching Engine ─────────────────────────────────────────────────────────────
MATCHING_RADIUS_KM=5
MATCHING_MAX_CANDIDATES=20
MATCHING_TOP_N=3
MATCHING_ACCEPTANCE_WINDOW_MS=15000
MATCHING_MAX_RETRY_COUNT=0
MATCHING_WEIGHT_DISTANCE=0.50
MATCHING_WEIGHT_RATING=0.30
MATCHING_WEIGHT_ACCEPTANCE=0.20

# ─── Monitoring ──────────────────────────────────────────────────────────────────
SENTRY_DSN=https://REPLACE@oXXXXXX.ingest.sentry.io/REPLACE

# ─── Throttling ──────────────────────────────────────────────────────────────────
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=300

# ─── CORS ────────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000
