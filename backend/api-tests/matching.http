### ACCEPTANCE TIMEOUT TEST

##################################################
##################################################

### DRIVER ONLINE AGAIN

POST {{baseUrl}}/drivers/online
Authorization: Bearer {{driverToken}}

###

PATCH {{baseUrl}}/drivers/location
Authorization: Bearer {{driverToken}}
Content-Type: application/json

{
"latitude": 30.0668,
"longitude": 79.0193
}

###

POST {{baseUrl}}/rides
Authorization: Bearer {{passengerToken}}
Content-Type: application/json

{
"pickupLat": 30.0668,
"pickupLng": 79.0193,
"destLat": 30.3165,
"destLng": 78.0322,
"pickupAddress": "IIT Roorkee",
"destAddress": "Haridwar"
}

###

# WAIT FOR ASSIGNED

# DO NOT ACCEPT

##################################################

### AFTER ACCEPTANCE WINDOW EXPIRES

##################################################

POST {{baseUrl}}/rides/{{rideId}}/cancel
Authorization: Bearer {{passengerToken}}
Content-Type: application/json

{
"reasonCode":"PASSENGER_CHANGED_MIND"
}

###

GET {{baseUrl}}/rides/{{rideId}}
Authorization: Bearer {{passengerToken}}

# EXPECTED:

#

# TIMED_OUT

#

# Driver ONLINE again

# Locks removed

# Timeout job removed
