### Login Driver

POST {{baseUrl}}/auth/login
Content-Type: application/json

{
"email": "driver@test.com",
"password": "StrongPassword123!"
}

### Login Passenger

POST {{baseUrl}}/auth/login
Content-Type: application/json

{
"email": "dev@test.com",
"password": "StrongPassword123!"
}

### Register Driver Profile

POST {{baseUrl}}/drivers/register
Authorization: Bearer {{driverToken}}
Content-Type: application/json

{
"vehicleNumber":"UK07AB1234",
"vehicleModel":"Swift",
"vehicleColor":"White"
}

###

### Duplicate Registration

POST {{baseUrl}}/drivers/register
Authorization: Bearer {{driverToken}}
Content-Type: application/json

{
"vehicleNumber":"UK07AB1234",
"vehicleModel":"Swift",
"vehicleColor":"White"
}

###

### Get Driver Profile

GET {{baseUrl}}/drivers/profile
Authorization: Bearer {{driverToken}}

###

### Update Driver Profile

PATCH {{baseUrl}}/drivers/profile
Authorization: Bearer {{driverToken}}
Content-Type: application/json

{
"vehicleModel":"Baleno",
"vehicleColor":"Blue"
}

###

### Go Online

POST {{baseUrl}}/drivers/online
Authorization: Bearer {{driverToken}}

###

### Update Location

PATCH {{baseUrl}}/drivers/location
Authorization: Bearer {{driverToken}}
Content-Type: application/json

{
"latitude":30.0668,
"longitude":79.0193
}

###

### Spam Rate Limit Test

PATCH {{baseUrl}}/drivers/location
Authorization: Bearer {{driverToken}}
Content-Type: application/json

{
"latitude":30.0669,
"longitude":79.0194
}

###

### Go Offline

POST {{baseUrl}}/drivers/offline
Authorization: Bearer {{driverToken}}

###

### Passenger Access Attempt

GET {{baseUrl}}/drivers/profile
Authorization: Bearer {{passengerToken}}
